# Base URL the platform panel uses to reach the Canopy backend (spac/001_poc.md §7).
# In dev, requests go through Vite's /api proxy to VITE_API_TARGET (see vite.config.ts),
# so leaving this as /api is correct for local development.
VITE_API_BASE=/api

# Where the dev proxy forwards /api requests (the running backend).
VITE_API_TARGET=http://localhost:3000
